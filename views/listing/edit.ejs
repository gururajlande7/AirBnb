<% layout("/layout/boilerplate.ejs") -%>

<div class="page-container">
  <div class="form-card">
    <h3>Edit listing</h3>
    <form class="needs-validation" novalidate action="/listing/<%= place._id %>?_method=put" method="post" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input required id="title" class="form-control" type="text" value="<%= place.title %>" name="listing[title]">
        <div class="invalid-feedback">Enter a valid title.</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea required id="description" class="form-control" name="listing[description]" rows="4"><%= place.description %></textarea>
        <div class="invalid-feedback">Enter a valid description.</div>
      </div>

      <% if(place.image && place.image.url){ %>
        <div class="mb-3">
          <img class="preview-img" src="<%= place.image.url %>" alt="<%= place.title %>">
        </div>
      <% } %>

      <div class="mb-3">
        <label for="image" class="form-label">Change image</label>
        <input id="image" class="form-control" type="file" name="listing[image]" accept="image/*">
      </div>

      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Price</label>
          <input required min="0" id="price" class="form-control" type="number" value="<%= place.price %>" name="listing[price]">
          <div class="invalid-feedback">Enter a valid price.</div>
        </div>

        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Country</label>
          <input required id="country" class="form-control" type="text" value="<%= place.country %>" name="listing[country]">
          <div class="invalid-feedback">Enter a valid country.</div>
        </div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input required id="location" class="form-control" type="text" value="<%= place.location %>" name="listing[location]">
        <div class="invalid-feedback">Enter a valid location.</div>
      </div>

      <button class="btn brand-btn" type="submit">Save</button>
      <a class="btn soft-btn ms-2" href="/listing/<%= place._id %>">Cancel</a>
    </form>
  </div>
</div>
